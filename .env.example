# Copy to `.env.local` for local development.

# --- Existing app dependencies (Sanity + Supabase) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LaunchDarkly (feature flags) ---
# Client-side ID (public) from your LaunchDarkly environment settings.
NEXT_PUBLIC_LD_CLIENT_SIDE_ID=

# Server-side settings for the kill-switch endpoint:
# `src/app/api/ld/kill-switch/route.ts`
LD_API_TOKEN=
LD_PROJECT_KEY=
LD_ENVIRONMENT_KEY=

# Simple shared secret to protect the kill-switch endpoint (send as `x-kill-switch-secret` header).
LD_KILL_SWITCH_SECRET=

